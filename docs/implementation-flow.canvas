    {
      "id": "nodeA2000000001",
      "type": "text",
      "x": 20,
      "y": 160,
      "width": 360,
      "height": 95,
      "text": "**mcp_server.py**\nstdlib MCP server (stdio JSON-RPC)\nforces UTF-8, forwards tool calls"
    },
    {
      "id": "nodeA3000000001",
      "type": "text",
      "x": 20,
      "y": 305,
      "width": 360,
      "height": 70,
      "color": "5",
      "text": "**HTTP POST -> 127.0.0.1:5005**\nJSON command body"
    },
    {
      "id": "nodeA4000000001",
      "type": "text",
      "x": 20,
      "y": 425,
      "width": 360,
      "height": 105,
      "text": "**BridgeServer.cs**  *(inside ArcGIS Pro)*\nTcpListener on loopback\ndispatch by command name"
    },
    {
      "id": "nodeA5000000001",
      "type": "text",
      "x": 20,
      "y": 580,
      "width": 360,
      "height": 80,
      "text": "**QueuedTask.Run**\nmarshal to the main CIM thread"
    },
    {
      "id": "nodeA6000000001",
      "type": "text",
      "x": 20,
      "y": 710,
      "width": 360,
      "height": 100,
      "color": "4",
      "text": "**Live ArcGIS Pro project**\nMap + Layout update on screen\n*(user watches)*"
    },
    {
      "id": "nodeA7000000001",
      "type": "text",
      "x": 430,
      "y": 425,
      "width": 300,
      "height": 105,
